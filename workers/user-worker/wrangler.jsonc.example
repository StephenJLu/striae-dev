{
  "name": "USER_WORKER_NAME",
  "account_id": "ACCOUNT_ID",
  "main": "src/user-worker.ts",
  "compatibility_date": "2026-03-26",
  "compatibility_flags": [
    "nodejs_compat"
  ], 
  
  "observability": { 
	"enabled": true
  },

   "kv_namespaces": [
    {
      "binding": "USER_DB",
      "id": "KV_STORE_ID"
    }
  ],

  "r2_buckets": [
    {
      "binding": "STRIAE_DATA",
      "bucket_name": "DATA_BUCKET_NAME"
    },
    {
      "binding": "STRIAE_FILES",
      "bucket_name": "FILES_BUCKET_NAME"
    }
  ],

  "placement": { "mode": "smart" }
}