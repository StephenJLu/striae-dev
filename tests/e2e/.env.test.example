# E2E Test Environment Variables
# Copy this file to .env.test (gitignored) and fill in real values.

# A test user with permission to create/edit cases.
# Use a dedicated test account — not a production user.
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=your-test-password

# TOTP secret for the test account's authenticator app (base32-encoded).
# Required if the test account has TOTP MFA enrolled.
# Find this in your authenticator app settings, or when TOTP was first set up.
# Example: JBSWY3DPEHPK3PXP
TEST_TOTP_SECRET=

# Set to 1 to reuse an existing .auth/session.json without re-logging in.
# Useful when re-running tests locally and the session is still valid.
SKIP_AUTH_SETUP=0

# Override the base URL if your dev server runs on a different port.
# PLAYWRIGHT_BASE_URL=http://localhost:7777
